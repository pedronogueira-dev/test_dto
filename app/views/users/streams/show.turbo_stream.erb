<%= turbo_stream.update "modal" do %>
  <%= render "users/partials/modal" do %>
    <h3>User</h3>
    <dl>
      <dt>Id</dt><dd><%= @user_hash[:id] %></dd>
      <dt>Name</dt><dd><%= "#{@user_hash[:first_name]} #{@user_hash[:last_name]}" %></dd>
      <dt>Email</dt><dd><%= @user_hash[:email_address] %></dd>
      <% if @user_hash[:access_token].present? %>
        <dt>Access Token</dt><dd><code><%= @user_hash[:access_token] %></code></dd>
      <% end %>
    </dl>
    <div class="mt">
      <%= link_to "Close", "#", data: { action: "click->modal#close" }, class: "btn" %>
    </div>
  <% end %>
<% end %>
